#!/usr/bin/env bash
#MISE description="Deploy: Infrastructure (Secrets, Route, Gateway)"

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# Use envsubst to replace $GEMINI_API_KEY in Secrets if needed
envsubst < "$ROOT/kubernetes/apps/infra/llm-secret.yaml" | kubectl apply -f -
envsubst < "$ROOT/kubernetes/apps/infra/llm-api-key-secret.yaml" | kubectl apply -f -
kubectl apply -f "$ROOT/kubernetes/apps/infra/ai-backend.yaml" \
              -f "$ROOT/kubernetes/apps/infra/provider-config.yaml" \
              -f "$ROOT/kubernetes/apps/infra/model-route.yaml" \
              -f "$ROOT/kubernetes/apps/infra/gateway.yaml"
