#!/usr/bin/env bash
#MISE description="Deploy: KAgent controller"

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

helm upgrade -i kagent-crds oci://ghcr.io/kagent-dev/kagent/helm/kagent-crds \
    --namespace kagent \
    --create-namespace
helm upgrade -i kagent oci://ghcr.io/kagent-dev/kagent/helm/kagent \
    --namespace kagent \
    --set registry=ghcr.io
# Wait for CRDs to be ready and apply the fix
kubectl wait --for=condition=established --timeout=60s crd/modelconfigs.kagent.dev
envsubst < "$ROOT/kubernetes/apps/infra/kagent-fix.yaml" | kubectl apply -f -
