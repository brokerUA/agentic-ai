#!/usr/bin/env bash
#MISE description="Applications: Deploy agents and configs (Kustomize)"
#MISE depends=["setup:flux"]

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"
# Substitute environment variables in YAML files before applying
# Note: kubectl kustomize can be used, but since we want to substitute $GEMINI_API_KEY
# which might be inside the resources, we pipe the kustomize output through envsubst
kubectl kustomize kubernetes | envsubst '$GEMINI_API_KEY' | kubectl apply -f -
